{{!< default}}

<div class="home">
    {{#unless pagination.prev}}
    {{!-- Hero --}}
    <section class="home-hero">
        <div class="container">
            <h1 class="home-hero-title">The WizLeads Blog: Data Scraping, Email Enrichment &amp; B2B Lead Generation 🚀</h1>
            <p class="home-hero-desc">Tutorials, tool comparisons, and actionable guides on Sales Navigator, email verification, and cold outreach. Written for agencies, SDRs, and growth teams who sell to businesses.</p>
            <div class="subscribe-form">
                <div class="hero-search-form">
                    <input type="text" class="hero-search-input" placeholder="Search articles..." id="hero-search-input" autocomplete="off">
                    <button type="button" class="hero-search-btn" id="hero-search-btn" aria-label="Search">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        Search
                    </button>
                </div>
                <div class="hero-search-results" id="hero-search-results"></div>
            </div>
        </div>
    </section>

    {{!-- Featured + Sidebar --}}
    {{#match @custom.show_featured_posts}}
    <section class="featured-section">
        <div class="container">
            <div class="featured-grid">
                {{#get "posts" limit="1" include="tags,authors"}}
                {{#foreach posts}}
                <div class="featured-main">
                    <a href="{{url}}" class="featured-card">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image size="l"}}" alt="{{title}}" class="featured-img" loading="eager">
                        {{/if}}
                        {{#primary_tag}}<span class="post-tag">{{name}}</span>{{/primary_tag}}
                        <h2 class="featured-title">{{title}}</h2>
                        <p class="featured-excerpt">{{excerpt words="30"}}</p>
                    </a>
                </div>
                {{/foreach}}
                {{/get}}
                <div class="featured-sidebar">
                    {{#get "posts" limit="4" offset="1" include="tags"}}
                    {{#foreach posts}}
                    <a href="{{url}}" class="sidebar-post">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image size="xs"}}" alt="{{title}}" class="sidebar-img" width="148" height="100" loading="lazy" decoding="async">
                        {{/if}}
                        <div class="sidebar-text">
                            {{#primary_tag}}<span class="post-tag">{{name}}</span>{{/primary_tag}}
                            <h3 class="sidebar-title">{{title}}</h3>
                        </div>
                    </a>
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </div>
    </section>
    {{/match}}

    {{!-- CTA Banner --}}
    <section class="cta-banner-section">
        <div class="container">
            <div class="cta-banner">
                <div class="cta-banner-grid"></div>
                <div class="cta-banner-orb cta-banner-orb-1"></div>
                <div class="cta-banner-orb cta-banner-orb-2"></div>
                <div class="cta-float" style="top:18px;right:320px;transform:rotate(1deg);">
                    <span style="font-size:16px;">🧭</span>
                    <span>Sales Navigator</span>
                </div>
                <div class="cta-float" style="top:18px;right:30px;transform:rotate(-0.8deg);">
                    <span style="font-size:16px;">⚡</span>
                    <span>Account-Less Mode</span>
                </div>
                <div class="cta-float" style="top:50%;right:270px;transform:translateY(-50%) rotate(-0.5deg);">
                    <span style="font-size:16px;">📧</span>
                    <span>Email Enrichment</span>
                </div>
                <div class="cta-float" style="top:50%;right:40px;transform:translateY(-50%) rotate(1.2deg);">
                    <img src="{{asset "images/logos/google-maps-icon.webp"}}" alt="" width="18" height="18">
                    <span>Google Maps</span>
                </div>
                <div class="cta-float" style="bottom:18px;right:340px;transform:rotate(0.8deg);">
                    <span style="font-size:16px;">⚙️</span>
                    <span>REST API</span>
                </div>
                <div class="cta-float" style="bottom:18px;right:60px;transform:rotate(-1deg);">
                    <span style="font-size:16px;">🛡️</span>
                    <span>Catchall Verification</span>
                </div>
                <div class="cta-banner-content">
                    <h2>{{@custom.cta_heading}}</h2>
                    <p>We do weekly giveaways of <strong>100% off</strong> coupon codes and exclusive deals.<br>Subscribe to the blog to enter.</p>
                    <form class="cta-banner-form" id="cta-subscribe-form">
                        <input type="text" name="name" placeholder="Your name" required>
                        <input type="email" name="email" placeholder="Email address" required>
                        <button type="submit">Subscribe</button>
                    </form>
                    <p class="cta-banner-msg" id="cta-subscribe-msg"></p>
                </div>
            </div>
        </div>
    </section>

    {{/unless}}

    {{!-- Posts Grid --}}
    <section class="posts-section">
        <div class="container">
            {{#unless pagination.prev}}
            <h2 class="section-heading">Stories & Latest Posts</h2>
            {{else}}
            <h2 class="section-heading">Page {{pagination.page}}</h2>
            {{/unless}}
            <div class="posts-grid">
                {{#foreach posts}}
                {{> "post-card"}}
                {{/foreach}}
            </div>
            {{#if pagination.next}}
            <div class="pagination">
                <a href="{{page_url pagination.next}}" class="btn-load-more">Load More</a>
            </div>
            {{/if}}
        </div>
    </section>
</div>
