{{!< default}}

<div class="home">
    {{#unless pagination.prev}}
    {{!-- Hero --}}
    <section class="home-hero">
        <div class="container">
            <h1 class="home-hero-title">The WizLeads Blog: Data Scraping, Email Enrichment &amp; B2B Lead Generation 🚀</h1>
            <p class="home-hero-desc">Tutorials, tool comparisons, and actionable guides on Sales Navigator, email verification, and cold outreach. Written for agencies, SDRs, and growth teams who sell to businesses.</p>
            <div class="subscribe-form">
                <form data-members-form="subscribe">
                    <input data-members-email type="email" placeholder="Email address" required>
                    <button type="submit" class="btn-subscribe">Subscribe</button>
                    <p class="message-loading">Sending...</p>
                    <p class="message-success">Great! Check your inbox for a confirmation email.</p>
                    <p class="message-error">Something went wrong. Please try again.</p>
                </form>
            </div>
        </div>
    </section>

    {{!-- Featured + Sidebar --}}
    <section class="featured-section">
        <div class="container">
            <div class="featured-grid">
                {{#get "posts" limit="1" include="tags,authors"}}
                {{#foreach posts}}
                <div class="featured-main">
                    <a href="{{url}}" class="featured-card">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image size="l"}}" alt="{{title}}" class="featured-img" loading="eager">
                        {{/if}}
                        {{#primary_tag}}<span class="post-tag">{{name}}</span>{{/primary_tag}}
                        <h2 class="featured-title">{{title}}</h2>
                        <p class="featured-excerpt">{{excerpt words="30"}}</p>
                    </a>
                </div>
                {{/foreach}}
                {{/get}}
                <div class="featured-sidebar">
                    {{#get "posts" limit="4" offset="1" include="tags"}}
                    {{#foreach posts}}
                    <a href="{{url}}" class="sidebar-post">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image size="xs"}}" alt="{{title}}" class="sidebar-img" width="148" height="100" loading="lazy" decoding="async">
                        {{/if}}
                        <div class="sidebar-text">
                            {{#primary_tag}}<span class="post-tag">{{name}}</span>{{/primary_tag}}
                            <h3 class="sidebar-title">{{title}}</h3>
                        </div>
                    </a>
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </div>
    </section>

    {{!-- CTA Banner --}}
    <section class="cta-banner-section">
        <div class="container">
            <div class="cta-banner">
                <div class="cta-banner-grid"></div>
                <div class="cta-banner-orb cta-banner-orb-1"></div>
                <div class="cta-banner-orb cta-banner-orb-2"></div>
                <div class="cta-float" style="top:24px;right:320px;transform:rotate(1deg);">
                    <span style="font-size:16px;">🧭</span>
                    <span>Sales Navigator</span>
                </div>
                <div class="cta-float" style="top:24px;right:30px;transform:rotate(-0.8deg);">
                    <span style="font-size:16px;">⚡</span>
                    <span>Account-Less Mode</span>
                </div>
                <div class="cta-float" style="top:50%;right:270px;transform:translateY(-50%) rotate(-0.5deg);">
                    <span style="font-size:16px;">📧</span>
                    <span>Email Enrichment</span>
                </div>
                <div class="cta-float" style="top:50%;right:40px;transform:translateY(-50%) rotate(1.2deg);">
                    <img src="{{asset "images/logos/google-maps-icon.webp"}}" alt="" width="18" height="18">
                    <span>Google Maps</span>
                </div>
                <div class="cta-float" style="bottom:24px;right:340px;transform:rotate(0.8deg);">
                    <span style="font-size:16px;">⚙️</span>
                    <span>REST API</span>
                </div>
                <div class="cta-float" style="bottom:24px;right:60px;transform:rotate(-1deg);">
                    <span style="font-size:16px;">🛡️</span>
                    <span>Catchall Verification</span>
                </div>
                <div class="cta-banner-content">
                    <h2>Win 10,000 Free <span>Credits</span> Every Month</h2>
                    <p>We do weekly giveaways of WizLeads 100% off coupon codes, free credits, and exclusive deals. Subscribe to the blog to enter.</p>
                    <form data-members-form="subscribe" class="cta-banner-form">
                        <input data-members-email type="email" placeholder="Email address" required>
                        <button type="submit">Subscribe</button>
                        <p class="message-loading" style="color:rgba(255,255,255,0.6);">Sending...</p>
                        <p class="message-success" style="color:#a5f3a3;">Great! Check your inbox for a confirmation email.</p>
                        <p class="message-error" style="color:#fca5a5;">Something went wrong. Please try again.</p>
                    </form>
                </div>
            </div>
        </div>
    </section>

    {{/unless}}

    {{!-- Posts Grid --}}
    <section class="posts-section">
        <div class="container">
            {{#unless pagination.prev}}
            <h2 class="section-heading">Stories & Latest Posts</h2>
            {{else}}
            <h2 class="section-heading">Page {{pagination.page}}</h2>
            {{/unless}}
            <div class="posts-grid">
                {{#foreach posts}}
                {{> "post-card"}}
                {{/foreach}}
            </div>
            {{#if pagination.next}}
            <div class="pagination">
                <a href="{{pagination.next}}" class="btn-load-more">Load More</a>
            </div>
            {{/if}}
        </div>
    </section>
</div>
