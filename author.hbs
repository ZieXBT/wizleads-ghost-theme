{{!< default}}

<div class="archive">
    {{#author}}
    <header class="author-header">
        <div class="container">
            <div class="author-header-inner">
                {{#if profile_image}}
                <img class="author-avatar"
                     src="{{img_url profile_image size="s"}}"
                     alt="{{name}}"
                     width="120" height="120"
                     loading="eager"
                     decoding="async">
                {{/if}}
                <div class="author-info">
                    <span class="post-tag">Author</span>
                    <h1 class="archive-title">{{name}}</h1>
                    {{#if bio}}<p class="archive-desc">{{bio}}</p>{{/if}}
                    <ul class="author-links">
                        {{#if location}}<li>{{location}}</li>{{/if}}
                        {{#if website}}<li><a href="{{website}}" rel="noopener me" target="_blank">Website</a></li>{{/if}}
                        {{#if twitter}}<li><a href="{{social_url type="twitter"}}" rel="noopener me" target="_blank">X</a></li>{{/if}}
                        {{#if facebook}}<li><a href="{{social_url type="facebook"}}" rel="noopener me" target="_blank">Facebook</a></li>{{/if}}
                    </ul>
                </div>
            </div>
        </div>
    </header>
    {{/author}}

    <section class="posts-section">
        <div class="container">
            <div class="posts-grid">
                {{#foreach posts}}
                {{> "post-card"}}
                {{/foreach}}
            </div>
            {{#if pagination.next}}
            <div class="pagination">
                <a href="{{pagination.next}}" class="btn-load-more">Load More</a>
            </div>
            {{/if}}
        </div>
    </section>
</div>
