{{!< default}}

{{#post}}
<article class="post-single">

    {{!-- Split Hero with gray background --}}
    <header class="post-hero-section">
        {{!-- Blurred feature image background --}}
        {{#if feature_image}}
        <div class="post-hero-bg">
            <img src="{{img_url feature_image size="s"}}" alt="" aria-hidden="true">
        </div>
        <div class="post-hero-blur"></div>
        {{/if}}
        <div class="container">
            <div class="post-hero-grid">
                <div class="post-hero-text">
                    {{#primary_tag}}
                    <a href="{{url}}" class="post-tag">{{name}}</a>
                    {{/primary_tag}}
                    <h1 class="post-title">{{title}}</h1>
                    {{#if custom_excerpt}}<p class="post-excerpt">{{custom_excerpt}}</p>{{/if}}
                    <div class="post-author-row">
                        {{#primary_author}}
                        <a href="{{url}}" class="post-author-link">
                            {{#if profile_image}}
                            <img src="{{img_url profile_image size="xs"}}" alt="{{name}}" class="post-author-avatar">
                            {{/if}}
                            <div class="post-author-info">
                                <span class="post-author-name">{{name}}</span>
                                <span class="post-author-meta">
                                    <time class="post-author-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
                                    <span class="post-reading-time" data-reading-time></span>
                                </span>
                                <time class="post-modified-date" datetime="{{date updated_at format="YYYY-MM-DD"}}" style="display:none;">Updated {{date updated_at format="MMMM D, YYYY"}}</time>
                            </div>
                        </a>
                        {{/primary_author}}
                        <div class="post-hero-share">
                            <a href="https://twitter.com/intent/tweet?url={{url absolute="true"}}&text={{encode title}}" target="_blank" rel="noopener" class="share-icon-btn" aria-label="Share on X">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                            </a>
                            <a href="https://www.facebook.com/sharer/sharer.php?u={{url absolute="true"}}" target="_blank" rel="noopener" class="share-icon-btn" aria-label="Share on Facebook">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                            </a>
                            <button type="button" class="share-icon-btn" data-share="copy" aria-label="Copy link">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
                {{#if feature_image}}
                <div class="post-hero-image">
                    <img src="{{img_url feature_image size="l"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" fetchpriority="high">
                    {{#if feature_image_caption}}<figcaption>{{feature_image_caption}}</figcaption>{{/if}}
                </div>
                {{/if}}
            </div>
        </div>
    </header>

    {{!-- Post Body — 3-column layout: TOC | Content | Banner --}}
    <div class="post-body">
        <div class="post-body-grid container">
            <aside class="post-toc-sidebar" aria-label="Table of contents" data-toc>
                <div class="post-toc-inner">
                    <p class="post-toc-label">In this article</p>
                    <ul class="post-toc-list" data-toc-list role="list"></ul>
                </div>
            </aside>

            <div class="post-content" data-content>
                {{content}}
            </div>

            <aside class="post-banner-sidebar" aria-label="Sponsored">
                {{> "banner-vertical"}}
            </aside>
        </div>
    </div>

    {{!-- Tags + Share --}}
    {{#if tags}}
    <div class="post-footer-meta">
        <div class="container">
            <div class="post-tags-share">
                <div class="post-tags-section">
                    <h4 class="meta-label">Tags</h4>
                    <div class="tag-list">
                        {{#foreach tags}}
                        <a href="{{url}}" class="tag-pill">{{name}}</a>
                        {{/foreach}}
                    </div>
                </div>
                {{#match @custom.show_share_buttons}}
                <div class="post-share-section">
                    <h4 class="meta-label">Share</h4>
                    <div class="share-icons">
                        <a href="https://twitter.com/intent/tweet?url={{url absolute="true"}}" target="_blank" rel="noopener" class="share-icon-lg"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
                        <a href="https://www.facebook.com/sharer/sharer.php?u={{url absolute="true"}}" target="_blank" rel="noopener" class="share-icon-lg"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
                        <a href="https://www.linkedin.com/sharing/share-offsite/?url={{url absolute="true"}}" target="_blank" rel="noopener" class="share-icon-lg"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.064 2.064 0 1 1 0-4.128 2.064 2.064 0 0 1 0 4.128zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
                        <button type="button" class="share-icon-lg" data-share="copy"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/></svg></button>
                    </div>
                </div>
                {{/match}}
            </div>
        </div>
    </div>
    {{/if}}

    {{!-- Comments --}}
    {{#match @custom.show_comments}}
    {{#if comments}}
    <div class="post-comments">
        <div class="container">
            {{comments}}
        </div>
    </div>
    {{/if}}
    {{/match}}

    {{!-- Related Posts --}}
    {{#match @custom.show_related_posts}}
    {{#get "posts" filter="id:-{{id}}" limit="3" include="tags,authors" as |related|}}
    {{#if related}}
    <section class="related-posts">
        <div class="container">
            <h2 class="section-heading">You might also like</h2>
            <div class="posts-grid">
                {{#foreach related}}
                {{> "post-card"}}
                {{/foreach}}
            </div>
        </div>
    </section>
    {{/if}}
    {{/get}}
    {{/match}}

</article>
{{/post}}
