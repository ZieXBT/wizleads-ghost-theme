<header class="floating-header" data-site-header>
    <a class="fh-logo" href="{{@site.url}}">
        {{#if @site.logo}}
        <img src="{{@site.logo}}" alt="{{@site.title}}" width="26" height="26">
        {{else}}
        <img src="{{asset "icons/favicon.svg"}}" alt="{{@site.title}}" width="26" height="26">
        {{/if}}
        {{@site.title}}
    </a>
    <nav class="fh-nav" data-nav aria-label="Main navigation">
        <div class="fh-dropdown">
            <button class="fh-dropdown-trigger">Products <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg></button>
            <div class="fh-dropdown-menu">
                <a href="https://wizleads.io/sales-navigator">LinkedIn Sales Navigator Scraper</a>
                <a href="https://wizleads.io/email-enrichment">Email Enrichment</a>
                <a href="https://wizleads.io/email-verification">Email Verification</a>
            </div>
        </div>
        {{navigation}}
    </nav>
    <div class="fh-actions">
        {{#if @site.members_enabled}}
            {{#if @member}}
                <a href="{{@site.url}}/#/portal/account" class="fh-login">Account</a>
            {{else}}
                <a href="{{@site.url}}/#/portal/signin" class="fh-login">Log in</a>
                <a href="{{@site.url}}/#/portal/signup" class="fh-cta">Subscribe</a>
            {{/if}}
        {{else}}
            <a href="https://app.wizleads.io/login" class="fh-login">Log in</a>
            <a href="https://app.wizleads.io/register" class="fh-cta">Get Started</a>
        {{/if}}
    </div>
    {{#unless @member}}
    <a href="{{@site.url}}/#/portal/signup" class="fh-mobile-cta">Subscribe</a>
    {{/unless}}
    <button type="button" class="fh-mobile-btn" data-nav-toggle aria-label="Menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
</header>
<div class="fh-mobile-menu" data-mobile-menu>
    <a href="https://wizleads.io/sales-navigator">LinkedIn Sales Navigator Scraper</a>
    <a href="https://wizleads.io/email-enrichment">Email Enrichment</a>
    <a href="https://wizleads.io/email-verification">Email Verification</a>
    {{navigation}}
    <div class="fh-mobile-actions">
        {{#if @site.members_enabled}}
            {{#if @member}}
                <a href="{{@site.url}}/#/portal/account" class="fh-login">Account</a>
            {{else}}
                <a href="{{@site.url}}/#/portal/signin" class="fh-login">Log in</a>
                <a href="{{@site.url}}/#/portal/signup" class="fh-cta">Subscribe</a>
            {{/if}}
        {{else}}
            <a href="https://app.wizleads.io/login" class="fh-login">Log in</a>
            <a href="https://app.wizleads.io/register" class="fh-cta">Get Started</a>
        {{/if}}
    </div>
</div>
