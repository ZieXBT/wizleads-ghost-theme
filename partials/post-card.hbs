<article class="post-card">
    <a href="{{url}}" class="post-card-link">
        {{#if feature_image}}
        <div class="post-card-image">
            <img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy" decoding="async">
            {{#if access}}{{else}}<span class="post-card-lock" aria-label="Members only">&#128274;</span>{{/if}}
        </div>
        {{/if}}
        <div class="post-card-content">
            {{#primary_tag}}<span class="post-tag">{{name}}</span>{{/primary_tag}}
            <h3 class="post-card-title">{{title}}</h3>
            {{#if excerpt}}<p class="post-card-excerpt">{{excerpt words="25"}}</p>{{/if}}
        </div>
    </a>
</article>
