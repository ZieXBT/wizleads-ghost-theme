{{!< default}}

<div class="archive">
    {{#tag}}
    <header class="archive-header">
        <div class="container">
            <span class="post-tag">Section</span>
            <h1 class="archive-title">{{name}}</h1>
            {{#if description}}
            <p class="archive-desc">{{description}}</p>
            {{/if}}
            <p class="archive-count">{{plural ../pagination.total empty='No posts' singular='% post' plural='% posts'}}</p>
        </div>
    </header>
    {{/tag}}

    <section class="posts-section">
        <div class="container">
            <div class="posts-grid">
                {{#foreach posts}}
                {{> "post-card"}}
                {{/foreach}}
            </div>
            {{#if pagination.next}}
            <div class="pagination">
                <a href="{{pagination.next}}" class="btn-load-more">Load More</a>
            </div>
            {{/if}}
        </div>
    </section>
</div>
